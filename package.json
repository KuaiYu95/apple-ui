{
  "name": "@yu-cq/apple-ui",
  "version": "0.1.4",
  "private": false,
  "description": "Apple-inspired React UI components.",
  "keywords": [
    "react",
    "ui",
    "components",
    "apple",
    "design-system"
  ],
  "license": "MIT",
  "author": "KuaiYu",
  "repository": {
    "type": "git",
    "url": "https://github.com/KuaiYu95/apple-ui"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "node -e \"const fs=require('fs'); for (const path of ['.next/dev/types','tsconfig.tsbuildinfo']) fs.rmSync(path,{ recursive: true, force: true })\" && next typegen && tsc --noEmit",
    "build:lib": "tsup src/index.ts --dts --format cjs,esm --out-dir dist --treeshake --clean --tsconfig tsconfig.build.json && node -e \"require('fs').cpSync('src/styles.css','dist/styles.css')\"",
    "build:all": "pnpm build && pnpm build:lib"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}